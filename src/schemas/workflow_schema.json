{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow",
  "type": "object",
  "required": ["id", "name", "nodes", "connections"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/triggerNode"
          },
          {
            "$ref": "#/definitions/conditionNode"
          },
          {
            "$ref": "#/definitions/actionNode"
          }
        ]
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "condition": { "type": "string", "enum": ["always", "if_true", "if_false"] }
        }
      }
    }
  },
  "definitions": {
    "baseNode": {
      "type": "object",
      "required": ["id", "type", "position"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "triggerNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "required": ["config"],
          "properties": {
            "type": { "const": "trigger" },
            "config": {
              "type": "object",
              "required": ["triggerType"],
              "properties": {
                "triggerType": {
                  "type": "string",
                  "enum": ["scheduled", "new_transaction", "income_received", "balance_threshold"]
                },
                "account": { "type": "string" },
                "tracking_start_date": { "type": "string" },
                "tracking_end_date": { "type": "string" },
                "schedule": {
                  "type": "object",
                  "properties": {
                    "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
                    "dayOfWeek": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday", "Any"] },
                    "dayOfMonth": { "type": "number", "minimum": 1, "maximum": 31 },
                    "time": { "type": "string", "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$" }
                  }
                },
                "threshold": {
                  "type": "object",
                  "properties": {
                    "amount": { "type": "number" },
                    "operator": { "type": "string", "enum": ["greater_than", "less_than", "equals"] }
                  }
                }
              },
              "allOf": [
                {
                  "if": { "properties": { "triggerType": { "const": "scheduled" } } },
                  "then": { "required": ["schedule"] }
                },
                {
                  "if": { "properties": { "triggerType": { "const": "balance_threshold" } } },
                  "then": { "required": ["threshold"] }
                }
              ]
            }
          }
        }
      ]
    },
    "conditionNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "required": ["config"],
          "properties": {
            "type": { "const": "condition" },
            "config": {
              "type": "object",
              "required": ["conditionType"],
              "properties": {
                "conditionType": {
                  "type": "string",
                  "enum": ["spending_threshold", "balance_check", "merchant_filter", "category_filter", "amount_range"]
                },
                "account": { "type": "string" },
                "merchant": { "type": "string" },
                "category": { "type": "string" },
                "amount": { "type": "number" },
                "operator": { "type": "string", "enum": ["greater_than", "less_than", "equals", "contains"] },
                "tracking_start_date": { "type": "string" },
                "tracking_end_date": { "type": "string" },
                "timeWindow": {
                  "type": "object",
                  "properties": {
                    "start": { "type": "string" },
                    "end": { "type": "string" },
                    "duration": { "type": "string" }
                  }
                }
              },
              "allOf": [
                {
                  "if": { "properties": { "conditionType": { "const": "spending_threshold" } } },
                  "then": { "required": ["amount", "operator"] }
                },
                {
                  "if": { "properties": { "conditionType": { "const": "balance_check" } } },
                  "then": { "required": ["amount", "operator"] }
                },
                {
                  "if": { "properties": { "conditionType": { "const": "merchant_filter" } } },
                  "then": { "required": ["merchant"] }
                },
                {
                  "if": { "properties": { "conditionType": { "const": "category_filter" } } },
                  "then": { "required": ["category"] }
                },
                {
                  "if": { "properties": { "conditionType": { "const": "amount_range" } } },
                  "then": { "required": ["amount", "operator"] }
                }
              ]
            }
          }
        }
      ]
    },
    "actionNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "required": ["config"],
          "properties": {
            "type": { "const": "action" },
            "config": {
              "type": "object",
              "required": ["actionType"],
              "properties": {
                "actionType": {
                  "type": "string",
                  "enum": ["transfer", "notify", "set_reminder"]
                },
                "fromAccount": { "type": "string" },
                "toAccount": { "type": "string" },
                "amount": { "type": "number" },
                "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                "message": { "type": "string" },
                "notificationType": { "type": "string", "enum": ["email", "sms", "push", "in_app"] },
                "tracking_start_date": { "type": "string" },
                "tracking_end_date": { "type": "string" }
              },
              "allOf": [
                {
                  "if": { "properties": { "actionType": { "const": "transfer" } } },
                  "then": { "required": ["fromAccount", "toAccount"] }
                },
                {
                  "if": { "properties": { "actionType": { "const": "notify" } } },
                  "then": { "required": ["message"] }
                },
                {
                  "if": { "properties": { "actionType": { "const": "set_reminder" } } },
                  "then": { "required": ["message"] }
                }
              ]
            }
          }
        }
      ]
    }
  }
} 