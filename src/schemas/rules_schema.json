{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutomationRule",
  "type": "object",
  "required": ["trigger", "action"],
  "properties": {
    "trigger": {
      "type": "object",
      "required": ["type", "account"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["new_transaction", "income_received", "monthly_timer"]
        },
        "account": {
          "oneOf": [
            { "type": "string", "enum": ["Any", "All"] },
            { "type": "string", "pattern": "^[A-Z][a-z]*$" }
          ]
        },
        "day_of_month": { "type": "number", "minimum": 1, "maximum": 31 }
      },
      "additionalProperties": false
    },
    "criteria": {
      "type": "object",
      "properties": {
        "merchant": { "type": "string" },
        "category": { "type": "string" },
        "amount_greater_than": { "type": "number", "minimum": 0 },
        "amount_less_than": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["type", "from_account"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transfer", "notify", "save"]
        },
        "from_account": {
          "type": "string",
          "oneOf": [
            { "enum": ["Any", "All"] },
            { "pattern": "^[A-Z][a-z]*$" }
          ]
        },
        "to_account": {
          "type": "string",
          "oneOf": [
            { "enum": ["Any", "All"] },
            { "pattern": "^[A-Z][a-z]*$" }
          ]
        },
        "dollar_amount": { "type": "number", "minimum": 0 },
        "percent_amount": { "type": "number", "minimum": 0, "maximum": 100 },
        "destination": { "type": "string" },
        "goal_name": { "type": "string" },
        "message": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "transfer" } } },
          "then": { "required": ["to_account"] }
        },
        {
          "if": { "properties": { "type": { "const": "notify" } } },
          "then": { "not": { "required": ["to_account"] } }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
