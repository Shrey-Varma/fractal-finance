{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutomationRule",
  "type": "object",
  "required": ["trigger", "action"],
  "properties": {
    "trigger": {
      "type": "object",
      "required": ["type", "account"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["new_transaction", "income_received", "tracking"]
        },
        "account": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "criteria": {
      "type": "object",
      "properties": {
        "merchant": { "type": "string" },
        "category": { "type": "string" },
        "amount_greater_than": { "type": "number", "minimum": 0 },
        "amount_less_than": { "type": "number", "minimum": 0 },
        "tracking_duration": { "type": "string" }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transfer", "notify"]
        },
        "from_account": {
          "type": "string"
        },
        "to_account": {
          "type": "string"
        },
        "dollar_amount": { "type": "number", "minimum": 0 },
        "percent_amount": { "type": "number", "minimum": 0, "maximum": 100 },
        "message": { "type": "string" },
        "frequency": {
          "type": "object",
          "properties": {
            "day_of_week": {
              "type": "string",
              "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday", "Any"]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "transfer" } } },
          "then": { "required": ["from_account", "to_account"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
