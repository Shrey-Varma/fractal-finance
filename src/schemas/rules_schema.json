{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutomationRule",
  "type": "object",
  "required": ["trigger", "action", "criteria"],
  "properties": {
    "trigger": {
      "type": "object",
      "required": ["type", "account"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["new_transaction", "income_received", "balance_threshold", "scheduled"]
        },
        "account": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "criteria": {
      "type": "object",
      "properties": {
        "merchant": { "type": "string" },
        "category": { "type": "string" },
        "amount_greater_than": { "type": "number", "minimum": 0 },
        "amount_less_than": { "type": "number", "minimum": 0 },
        "tracking_start_date": { "type": "string"},
        "tracking_end_date": {"type": "string"}
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transfer", "notify"]
        },
        "from_account": {
          "type": "string"
        },
        "to_account": {
          "type": "string"
        },
        "dollar_amount": { "type": "number", "minimum": 0 },
        "percent_amount": { "type": "number", "minimum": 0, "maximum": 100 },
        "message": { "type": "string" },
        "frequency": {
          "type": "object",
          "properties": {
            "day_of_week": {
              "type": "string",
              "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday", "Any"]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "transfer" } } },
          "then": { "required": ["from_account", "to_account"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "trigger": { "properties": { "type": { "const": "balance_threshold" } }}}},
      "then": {"properties": {"criteria": {"oneOf": [{ "required": ["amount_greater_than"] }, { "required": ["amount_less_than"] }]}}}
    }
  ],
  "additionalProperties": false
}
