{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AutomationRule",
    "type": "object",
    "required": ["trigger", "action", "parameters"],
    "properties": {
      "trigger": {
        "type": "string",
        "enum": [
          "income_received",
          "new_transaction",
          "monthly_timer",
          "daily_timer",
          "balance_changed",
          "category_spending_threshold"
        ]
      },
      "condition": {
        "type": ["object", "null"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "amount_greater_than",
              "amount_less_than",
              "category_is",
              "merchant_is",
              "day_is",
              "account_is"
            ]
          },
          "value": { "type": ["number", "string"] },
          "category": { "type": "string" },
          "account": { "type": "string" },
          "day": { "type": "string" },
          "merchant": { "type": "string" }
        },
        "required": ["type"]
      },
      "action": {
        "type": "string",
        "enum": [
          "transfer",
          "notify",
          "save",
          "invest",
          "freeze_card",
          "round_up_and_save"
        ]
      },
      "parameters": {
        "type": "object",
        "oneOf": [
          {
            "title": "transfer with percentage",
            "required": ["amount_pct", "destination"],
            "properties": {
              "amount_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "destination": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "transfer with fixed amount",
            "required": ["amount", "destination"],
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "destination": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "notify",
            "required": ["message"],
            "properties": {
              "message": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "save",
            "required": ["amount", "goal_name"],
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "goal_name": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "invest",
            "required": ["amount", "asset"],
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "asset": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "freeze_card",
            "required": ["account"],
            "properties": {
              "account": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "title": "round_up_and_save",
            "required": ["destination"],
            "properties": {
              "destination": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "additionalProperties": false
  }
  